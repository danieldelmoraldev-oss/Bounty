PORT=4000
# Connection string a nivel de cluster, SIN nombre de base de datos: el
# nombre real (bounty_mock o bounty_live) lo elige el código según DATA_MODE.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Cluster0
# mock -> base "bounty_mock" (la que llena `pnpm seed` con datos falsos).
# live -> base "bounty_live" (arranca vacía, se llena con uso real).
DATA_MODE=mock
# Cualquier cadena larga y aleatoria. Genera una con:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
# Opcional, solo se usa a partir de la Fase 3 (generación de retos con IA).
OPENAI_API_KEY=
